# Copy to .env and adjust if needed. docker-compose uses these; defaults work for local dev.

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=assetblock
POSTGRES_PORT=5432

# MinIO
MINIO_ROOT_USER=assetblock
MINIO_ROOT_PASSWORD=dev_minio_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Redis
REDIS_PORT=6379

# Mailpit (local SMTP inbox only; bind to loopback)
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# DataProtection:KeysPath is NOT configured here.
# It is a server-side filesystem path set in appsettings.Development.json or .NET User Secrets.
# Leaf directory must be dedicated (dataprotection-keys / assetblock-dataprotection-keys*).
# Production on Linux/containers: DataProtection:ProtectionMode=Certificate|Kms (fail-fast otherwise).
# See asblock-backend/README.md.
