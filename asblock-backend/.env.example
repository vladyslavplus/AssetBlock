# Copy to .env and adjust if needed. docker-compose uses these; defaults work for local dev.

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=assetblock
POSTGRES_PORT=5432

# MinIO
MINIO_ROOT_USER=assetblock
MINIO_ROOT_PASSWORD=dev_minio_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Redis
REDIS_PORT=6379
