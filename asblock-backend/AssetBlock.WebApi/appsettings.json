{
  "ConnectionStrings": {
    "DefaultConnection": "<default-connection-string>",
    "Redis": "<default-redis-connection-string>"
  },
  "Database": {
    "AutoMigrate": false,
    "EnsureCreated": false,
    "SeedDemoAssets": false
  },
  "Jwt": {
    "Issuer": "<AssetBlock>",
    "Audience": "<AssetBlock.Api>",
    "Key": "<dev-secret-key-min-32-characters-long-for-hmac>",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Minio": {
    "Endpoint": "<minio-endpoint>:9000",
    "Bucket": "<bucket-name>",
    "AccessKey": "<minio-access-key>",
    "SecretKey": "<minio-secret-key>",
    "UseSsl": true
  },
  "Encryption": {
    "KeyBase64": "<base64-encoded-encryption-key>"
  },
  "Stripe": {
    "SecretKey": "<stripe-secret-key>",
    "WebhookSecret": "<stripe-webhook-secret>",
    "DefaultSuccessUrl": "<default-success-url>",
    "DefaultCancelUrl": "<default-cancel-url>"
  },
  "FileUpload": {
    "MaxFileBytes": 262144000,
    "AllowedExtensions": [ ".zip", ".7z", ".rar", ".tar", ".tar.gz", ".tgz" ]
  },
  "Email": {
    "Provider": "Smtp",
    "FromName": "<AssetBlock>",
    "FromAddress": "<noreply@example.com>",
    "PublicAppBaseUrl": "<public-app-base-url>",
    "MessageIdDomain": "<message-id-domain>",
    "Smtp": {
      "Host": "<smtp-host>",
      "Port": 1025,
      "Security": "NONE",
      "Username": "",
      "Password": "",
      "TimeoutSeconds": 30
    }
  },
  "DataProtection": {
    "KeysPath": "<dataprotection-keys-path>",
    "ProtectionMode": "",
    "CertificatePath": "",
    "CertificatePassword": "",
    "CertificateThumbprint": "",
    "KmsKeyId": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Enrichers.Environment"
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "AllowedHosts": "*"
}
