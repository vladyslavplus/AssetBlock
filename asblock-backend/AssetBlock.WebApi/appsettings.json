{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },
  "Database": {
    "AutoMigrate": true,
    "EnsureCreated": false
  },
  "Jwt": {
    "Issuer": "AssetBlock",
    "Audience": "AssetBlock.Api",
    "Key": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Minio": {
    "Endpoint": "localhost:9000",
    "Bucket": "assets",
    "AccessKey": "",
    "SecretKey": "",
    "UseSsl": false
  },
  "Encryption": {
    "KeyBase64": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Enrichers.Environment"
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
