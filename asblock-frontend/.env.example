# Copy to .env.local (or another ignored file). Do not commit real secrets.

# Browser → API (CORS). Often HTTPS in local dev (dotnet https profile).
NEXT_PUBLIC_API_BASE_URL=https://localhost:7000

# Next.js server (Route Handlers) → API. Node.js does NOT trust the ASP.NET dev HTTPS cert by default,
# so server-side login/session will fail with "self-signed certificate" unless you either:
#   - set this to HTTP (recommended for local): http://localhost:5088
#   - or use NODE_OPTIONS=--use-system-ca / a trusted dev cert
ASSETBLOCK_API_BASE_URL=http://localhost:5088

# If you run the API HTTP-only, you can use the same URL for both:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5088

# CORS on the API must allow this Next.js origin (default http://localhost:3000):
# asblock-backend → appsettings.Development.json → Cors:AllowedOrigins

# Stripe Checkout redirect URLs are configured on the API via User Secrets
# (Stripe:DefaultSuccessUrl / Stripe:DefaultCancelUrl), not in this frontend env file.
# Frontend payment routes live under /checkout/success and /checkout/cancel; the API may
# use /payment/* URLs that redirect there.
